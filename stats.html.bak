          <tr><td>2025-10</td><td>416</td></tr>
          <tr><td>2025-11</td><td>309</td></tr>
          <tr><td>2025-12</td><td>360</td></tr>
          <tr><td>2026-01</td><td>365</td></tr>
          <tr><td>2026-02</td><td>360</td></tr>
          <tr><td>2026-03</td><td>446</td></tr>
