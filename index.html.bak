:root { --bg: #0d1117; --surface: #151b23; --border: #252d38; --text: #e6edf3; --text-muted: #7d8590; --accent: #58a6ff; }
body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif; background: var(--bg); color: var(--text); line-height: 1.7; max-width: 860px; margin: 0 auto; padding: 32px; }
